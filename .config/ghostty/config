# vim: commentstring=#\ %s
window-padding-color = background
font-size=13
font-family = "RecMonoDuotone Nerd Font"
font-feature = -calt
font-feature = -liga
font-feature = -dlig
font-feature = -clig
theme = Catppuccin Mocha

background = #0f0f11
background-opacity=0.92
# background-blur = 30

# disable default bindings
keybind = ctrl+comma=unbind
keybind = ctrl+shift+n=unbind
keybind = alt+c=unbind
keybind = alt+shift+c=unbind
keybind = super+ctrl+shift+up=unbind
keybind = super+ctrl+shift+equal=unbind
keybind = super+ctrl+shift+left=unbind
keybind = super+ctrl+shift+down=unbind
keybind = super+ctrl+shift+right=unbind
keybind = super+ctrl+right_bracket=unbind
keybind = super+ctrl+left_bracket=unbind
keybind = ctrl+shift+e=unbind
keybind = ctrl+shift+o=unbind
keybind = ctrl+shift+i=unbind

keybind = ctrl+shift+w=close_window
keybind = ctrl+shift+page_up=move_tab:1
keybind = ctrl+shift+page_down=move_tab:-1

keybind = ctrl+shift+z=toggle_split_zoom
# keybind = shift+enter=text:\x1b\r
keybind = shift+enter=text:\x0a
