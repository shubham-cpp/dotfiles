#!/usr/bin/env bash

case "$1" in
preview)
    row="$2"
    if echo "$row" | grep -vqP '^\d+\t\[\[ binary data .* \]\]'; then
        printf '\e[3;0;0t' # sixel-clear
        echo "$row" | cliphist decode
    else
        echo "$row" | cliphist decode | chafa --clear -f sixel -s "${FZF_PREVIEW_COLUMNS}x${FZF_PREVIEW_LINES}"
    fi
    ;;

*)
    id="$(cliphist list | fzf \
        --preview-window="top" \
        --layout=reverse \
        --preview "$(realpath "$0") preview {}" \
        --bind 'ctrl-y:execute-silent(echo {} | cliphist decode | wl-copy)' \
        --bind 'ctrl-x:execute-silent(echo {} | cliphist delete)+reload(cliphist list)' \
        --bind 'ctrl-delete:execute-silent(echo {} | cliphist delete)+reload(cliphist list)' \
        --header 'Ctrl-Y: copy & stay | Ctrl-X or Ctrl-Del to delete entry'
    )"
    test -z "$id" && exit

    cliphist decode <<<"$id" | wl-copy
    ;;

esac
