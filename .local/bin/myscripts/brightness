#!/usr/bin/env bash

amount=${2:-10}

get_brightness() {
  brightnessctl i | awk -F'[()%]' '
    /Current brightness/ {
      value = int($2 + 0.5)
      if (value < 0) value = 0
      if (value > 100) value = 100
      print value
    }
  '
}

update_brightness() {
  value=$(get_brightness)
  notify-send \
    -a "System OSD" \
    -c device \
    -t 1800 \
    -i display-brightness-symbolic \
    -h int:value:"$value" \
    -h string:x-canonical-private-synchronous:backlight \
    -r 10011 \
    "Brightness" "${value}%"
  pidof dwmblocks | xargs -r kill -36
  pgrep polybar && polybar-msg action mbrightness hook 0
}

case "$1" in
inc)
  brightnessctl s "$amount"%+
  update_brightness
  ;;
dec)
  brightnessctl s "$amount"%-
  update_brightness
  ;;
get)
  brightnessctl -m | cut -d, -f4
  ;;
*)
  echo "Program requires argument inc,dec"
  notify-send -u critical -i dialog-error "Brightness" "Program requires argument inc, dec, or get"
  exit 1
  ;;
esac
